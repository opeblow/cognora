# =============================================================================
# Cognora Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql://cognora:cognora@db:5432/cognora
POSTGRES_USER=cognora
POSTGRES_PASSWORD=change-this-in-production
POSTGRES_DB=cognora

# --- Redis (Cache + Celery Broker) ---
REDIS_URL=redis://redis:6379/0

# --- JWT Authentication ---
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-in-production

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini

# --- Brave Search API (for grounded quizzes/exams) ---
BRAVE_API_KEY=your-brave-api-key

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxxxxx
FROM_EMAIL="Cognora <noreply@cognora.app>"

# --- Google OAuth ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# --- Paystack (Credit Purchases) ---
# PAYSTACK_SECRET_KEY=sk_test_xxxxxxxx
# PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxx

# --- Live Teaching (Agora) ---
# AGORA_APP_ID=
# AGORA_APP_CERTIFICATE=
# LIVE_SESSION_PROVIDER=mock  # change to 'agora' when ready

# --- Frontend URLs (used in email links, CORS, and WebSocket) ---
CORS_ORIGINS=["http://localhost:3000"]
APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# --- Uploads ---
# UPLOAD_DIR=uploads
# MAX_UPLOAD_SIZE_MB=50

# --- Monitoring (Sentry) ---
# SENTRY_DSN=https://your-dsn@o123456.ingest.sentry.io/123456

# --- Database Connection Pool ---
# DB_POOL_SIZE=20
# DB_MAX_OVERFLOW=40

# --- Rate Limiting ---
# RATE_LIMIT_PER_MINUTE=60
